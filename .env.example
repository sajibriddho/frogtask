# NextAuth Configuration
# Generate secret using: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# MongoDB Connection
# Example:
# mongodb://127.0.0.1:27017/frogtask
# OR MongoDB Atlas:
# mongodb+srv://username:password@cluster.mongodb.net/db_name
MONGODB_URI=